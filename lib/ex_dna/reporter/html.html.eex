<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ExDNA Report</title>
<style><%= css() %></style>
</head>
<body>
<header>
  <h1>ExDNA</h1>
  <p class="subtitle">Code Duplication Report</p>
</header>
<section class="summary">
  <div class="stat">
    <span class="stat-value"><%= stats.files_analyzed %></span>
    <span class="stat-label">Files analyzed</span>
  </div>
  <div class="stat">
    <span class="stat-value"><%= stats.total_clones %></span>
    <span class="stat-label">Clones found</span>
  </div>
  <div class="stat">
    <span class="stat-value"><%= stats.type_i_count %></span>
    <span class="stat-label">Type I (exact)</span>
  </div>
  <div class="stat">
    <span class="stat-value"><%= stats.type_ii_count %></span>
    <span class="stat-label">Type II (renamed)</span>
  </div>
  <div class="stat">
    <span class="stat-value"><%= Map.get(stats, :type_iii_count, 0) %></span>
    <span class="stat-label">Type III (near-miss)</span>
  </div>
  <div class="stat">
    <span class="stat-value">~<%= stats.total_duplicated_lines %></span>
    <span class="stat-label">Duplicated lines</span>
  </div>
</section>
<%= if clones == [] do %>
  <p class="no-clones">✓ No code duplication detected</p>
<% else %>
  <%= for {clone, index} <- Enum.with_index(clones, 1) do %>
    <% snippets_list = clone.source_snippets %>
    <details class="clone-card" open>
      <summary>
        <span class="badge <%= badge_class(clone.type) %>"><%= type_badge(clone.type) %></span>
        <span class="clone-title">#<%= index %></span>
        <span class="meta"><%= clone.mass %> nodes<%= format_similarity(clone.similarity) %></span>
      </summary>
      <div class="clone-body">
        <div class="locations">
          <%= for frag <- clone.fragments do %>
            <% path = relative_path(frag.file) %>
            <% label = if frag.line > 0, do: "#{path}:#{frag.line}", else: path %>
            <a class="location" href="<%= file_uri(frag.file, frag.line) %>"><%= escape(label) %></a>
          <% end %>
        </div>
        <%= for {snippet, i} <- Enum.with_index(snippets_list, 1) do %>
          <div class="snippet">
            <%= if length(snippets_list) > 1 do %>
              <div class="snippet-label">Fragment <%= i %></div>
            <% end %>
            <pre><code><%= highlight(snippet) %></code></pre>
          </div>
        <% end %>
        <%= render_suggestion(clone.suggestion) %>
        <%= render_behaviour_suggestion(clone.behaviour_suggestion) %>
      </div>
    </details>
  <% end %>
<% end %>
<footer>Generated by ExDNA</footer>
</body>
</html>
